{
  "name": "@kakashi/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "kakashi": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --sourcemap",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.0.1",
    "@kakashi/core": "workspace:*",
    "@kakashi/server": "workspace:*",
    "commander": "^14.0.2",
    "picocolors": "^1.1.1"
  }
}
