{
  "name": "kakashi",
  "version": "0.2.0",
  "description": "Codex-powered GitHub multi-repository capability fusion system.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/eust-w/kakashi#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eust-w/kakashi.git"
  },
  "bugs": {
    "url": "https://github.com/eust-w/kakashi/issues"
  },
  "keywords": [
    "codex",
    "github",
    "ai-agent",
    "cli",
    "capability-graph",
    "code-generation",
    "repository-analysis"
  ],
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @kakashi/server dev",
    "dev:web": "pnpm --filter @kakashi/web dev",
    "lint": "eslint .",
    "audit:high": "pnpm audit --audit-level high",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "RUN_REAL_INTEGRATION=1 vitest run -c vitest.integration.config.ts",
    "test:codex": "RUN_CODEX_INTEGRATION=1 vitest run -c vitest.integration.config.ts tests/integration/codex-real.test.ts",
    "test:e2e": "playwright test",
    "release:package": "node scripts/build-release.mjs",
    "release:executable": "node scripts/build-executable.mjs",
    "verify:release-assets": "node scripts/verify-release-assets.mjs",
    "kakashi": "node apps/cli/dist/index.js",
    "doctor": "node apps/cli/dist/index.js doctor"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.15",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "postject": "1.0.0-alpha.6",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.15"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1"
    }
  }
}
